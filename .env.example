# Application Environment (development / production)
ESD_ENV=production

# Flask Secret Key
SECRET_KEY=enter-a-long-secure-random-string-here

# Database URL
# For local run, defaults to sqlite:///database/esd_monitoring.db
# For Render with a persistent disk mounted at /data, set to:
# DATABASE_URL=sqlite:////data/esd_monitoring.db
DATABASE_URL=sqlite:///database/esd_monitoring.db

# KC868 Controller Config
KC868_HOST=192.168.1.50
KC868_PORT=502
KC868_SIMULATED=true

# Polling Interval (in milliseconds)
POLL_INTERVAL_MS=750

# Log Retention Policy
RETENTION_DAYS=30
